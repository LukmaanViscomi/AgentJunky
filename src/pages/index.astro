---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => a.data.seriesNumber - b.data.seriesNumber);

const topics = [
  { name: 'Google Cloud & ADK', desc: 'Gemini Enterprise Agent Platform, Agent Development Kit, Deployments' },
  { name: 'AWS', desc: 'Bedrock agents and the infra around them' },
  { name: 'Azure', desc: 'Azure AI Foundry and agent tooling' },
];
---
<BaseLayout title="Home">
  <main class="max-w-3xl mx-auto px-4 sm:px-6">
    <section class="pt-14 sm:pt-28 pb-10">
      <div class="rounded-3xl border border-white/10 bg-white/[0.04] backdrop-blur-xl shadow-[0_0_80px_-20px_rgba(55,138,221,0.35)] p-6 sm:p-10 lg:p-14">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 sm:gap-8 text-center sm:text-left">
          <img
            src="/agent_junky_weblogo.png"
            alt="Agent Junky"
            class="h-24 w-24 sm:h-36 sm:w-36 md:h-44 md:w-44 shrink-0 rounded-2xl drop-shadow-[0_0_40px_rgba(55,138,221,0.45)]"
          />
          <div>
            <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs tracking-wide text-accent">
              AGENT ENGINEERING, IN PUBLIC
            </span>
            <h1 class="mt-6 text-4xl sm:text-5xl font-medium tracking-tight text-white">
              Agent Junky
            </h1>
            <p class="mt-4 text-lg text-muted max-w-xl">
              Building intelligent agents. Sharing everything — the wins, the 2am debugging sessions, and the one config flag that quietly broke everything.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="grid sm:grid-cols-3 gap-4 py-10">
      {topics.map((topic) => (
        <div class="group rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-xl p-5 transition-all hover:-translate-y-1 hover:border-accent/40 hover:bg-white/[0.06] hover:shadow-[0_8px_40px_-12px_rgba(55,138,221,0.45)]">
          <p class="text-sm font-medium text-white">{topic.name}</p>
          <p class="mt-1 text-xs text-muted">{topic.desc}</p>
        </div>
      ))}
    </section>

    <section class="pb-24 pt-10">
      <h2 class="text-sm tracking-wide text-muted uppercase mb-6">Latest posts</h2>
      <ul class="space-y-4">
        {posts.map((post) => (
          <li class="group rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-xl p-5 transition-all hover:-translate-y-1 hover:border-accent/40 hover:bg-white/[0.06] hover:shadow-[0_8px_40px_-12px_rgba(55,138,221,0.45)]">
            <p class="text-xs tracking-wide text-accent mb-1">
              SERIES #{post.data.seriesNumber}
            </p>
            <a href={`/posts/${post.id.replace(/\.mdx?$/, '')}/`} class="text-lg font-medium text-white hover:underline">
              {post.data.title}
            </a>
            <p class="text-sm text-muted mt-2">{post.data.excerpt}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>
