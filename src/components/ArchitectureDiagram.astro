---
const localItems = [
  { title: 'Browser', sub: 'ADK Dev UI · 127.0.0.1:8080/dev-ui' },
  { title: 'ADK Web Server', sub: 'Uvicorn' },
  { title: 'ReAct Agent + Tools', sub: 'Gemini via Vertex AI' },
  { title: 'Python 3.11', sub: 'managed with uv' },
];
const localTools = ['VS Code', 'PowerShell', 'gcloud CLI'];

const cloudItems = [
  { title: 'Vertex AI', sub: 'gemini-2.5-pro · gemini-2.0-flash' },
  { title: 'Cloud Storage + Secret Manager', sub: 'artifacts & secrets' },
  { title: 'Cloud Logging + Monitoring', sub: 'observability' },
  { title: 'IAM', sub: 'permissions & service accounts' },
];
const cloudTools = ['Cloud Build', 'Artifact Registry', 'Terraform'];

const futureItems = ['MCP Servers', 'A2A Protocol', 'External APIs', 'Enterprise Data'];
---
<div class="not-prose my-10 rounded-3xl border border-white/10 bg-white/[0.03] backdrop-blur-xl p-6 sm:p-8 shadow-[0_0_80px_-30px_rgba(55,138,221,0.35)]">
  <p class="text-center text-xs tracking-widest text-muted uppercase mb-6">Architecture Overview</p>

  <div class="rounded-2xl border border-emerald-400/20 bg-emerald-400/[0.05] p-5">
    <p class="text-sm font-semibold text-emerald-300 tracking-wide">LOCAL</p>
    <p class="text-[11px] text-muted mb-4">Windows 11 machine</p>
    <div class="grid sm:grid-cols-2 gap-2">
      {localItems.map((item) => (
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-3 py-2">
          <p class="text-sm text-white">{item.title}</p>
          <p class="text-[11px] text-muted">{item.sub}</p>
        </div>
      ))}
    </div>
    <div class="mt-3 flex flex-wrap gap-2">
      {localTools.map((tool) => (
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-2.5 py-1 text-[11px] text-muted">{tool}</span>
      ))}
    </div>
  </div>

  <div class="flex items-center justify-center gap-3 py-4">
    <div class="h-px flex-1 max-w-16 bg-gradient-to-r from-transparent to-accent"></div>
    <span class="whitespace-nowrap rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-center text-[10px] tracking-wide text-accent">
      🔒 HTTPS/gRPC · ADC Auth
    </span>
    <div class="h-px flex-1 max-w-16 bg-gradient-to-l from-transparent to-accent"></div>
  </div>

  <div class="rounded-2xl border border-accent/20 bg-accent/[0.05] p-5">
    <p class="text-sm font-semibold text-accent tracking-wide">GOOGLE CLOUD</p>
    <p class="text-[11px] text-muted mb-4 font-mono">agentic-ai-labs-502223</p>
    <div class="grid sm:grid-cols-2 gap-2">
      {cloudItems.map((item) => (
        <div class="rounded-lg border border-white/10 bg-white/[0.03] px-3 py-2">
          <p class="text-sm text-white">{item.title}</p>
          <p class="text-[11px] text-muted">{item.sub}</p>
        </div>
      ))}
    </div>
    <div class="mt-3 flex flex-wrap gap-2">
      {cloudTools.map((tool) => (
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-2.5 py-1 text-[11px] text-muted">{tool}</span>
      ))}
    </div>
  </div>

  <div class="mt-6 pt-6 border-t border-dashed border-white/10">
    <p class="text-center text-[11px] tracking-widest text-muted uppercase mb-3">Future integrations</p>
    <div class="flex flex-wrap justify-center gap-2">
      {futureItems.map((item) => (
        <span class="rounded-full border border-dashed border-white/15 px-3 py-1 text-[11px] text-muted">{item}</span>
      ))}
    </div>
  </div>
</div>
